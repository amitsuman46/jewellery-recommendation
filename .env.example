# Google AI Studio / Gemini — required for POST /api/recommend
GEMINI_API_KEY=

# Optional: default is gemini-2.5-flash (gemini-2.0-flash is not available for new API keys)
# GEMINI_MODEL=gemini-2.5-flash

# API server
PORT=3001

# CORS: Vite dev server origin(s), comma-separated
WEB_ORIGIN=http://localhost:5173
